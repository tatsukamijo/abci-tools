#!/bin/bash

# ABCI Interactive Shell Launcher
# Usage: qsub_shell [OPTIONS]
# Options:
#   --full              Full node mode (rt_HF: 8 GPUs, 192 CPUs)
#   --no-gpu            CPU-only mode (rt_HC: 32 CPUs)
#   -t, --time MINUTES  Time limit in minutes (default: 30)
#   -p, --project NAME  Project group name (default: gch51606)
#   -q, --queue NAME    Resource type override (rt_HG, rt_HF, rt_HC)
#   -r, --resv ID       Reservation ID (e.g., R1538111)
#   -n, --name NAME     Job name (default: interactive)
#   -h, --help          Show this help

set -e

# Default values
TIME_LIMIT=30
PROJECT_GROUP="gch51606"
QUEUE_NAME="rt_HG"
RESERVATION_ID=""
JOB_NAME="interactive"

# Help function
show_help() {
    cat << EOF
ABCI Interactive Shell Launcher

Usage: qsub_shell [OPTIONS]

Options:
    --full              Full node mode (rt_HF: 8 GPUs, 192 CPUs)
    --no-gpu            CPU-only mode (rt_HC: 32 CPUs)
    -t, --time MINUTES  Time limit in minutes (default: 30)
    -p, --project NAME  Project group name (default: gch51606)
    -q, --queue NAME    Resource type override (rt_HG, rt_HF, rt_HC)
    -r, --resv ID       Reservation ID (e.g., R1538111)
    -n, --name NAME     Job name (default: interactive)
    -h, --help          Show this help

Examples:
    qsub_shell                           # Default: 1 GPU (rt_HG), 30 min
    qsub_shell --full -t 60             # Full node (8 GPUs), 60 minutes
    qsub_shell --no-gpu                 # CPU-only mode
    qsub_shell --resv R1538111           # Reserved node, 1 GPU
    qsub_shell --resv R1538111 --full    # Reserved node, full node

Resource Types (CPU/Memory are fixed per type):
    rt_HG: 1 GPU,  16 CPUs, 160GB memory (default)
    rt_HF: 8 GPUs, 192 CPUs, 1920GB memory (full node)
    rt_HC: 0 GPUs, 32 CPUs, 320GB memory (CPU-only)
EOF
}

# Parse command line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --full)
            QUEUE_NAME="rt_HF"
            shift
            ;;
        --no-gpu)
            QUEUE_NAME="rt_HC"
            shift
            ;;
        -t|--time)
            TIME_LIMIT="$2"
            shift 2
            ;;
        -p|--project)
            PROJECT_GROUP="$2"
            shift 2
            ;;
        -q|--queue)
            QUEUE_NAME="$2"
            shift 2
            ;;
        -r|--resv)
            RESERVATION_ID="$2"
            shift 2
            ;;
        -n|--name)
            JOB_NAME="$2"
            shift 2
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            echo "Error: Unknown option $1" >&2
            show_help
            exit 1
            ;;
    esac
done

# Validate inputs
if ! [[ "$TIME_LIMIT" =~ ^[0-9]+$ ]] || [ "$TIME_LIMIT" -lt 1 ]; then
    echo "Error: Time limit must be a positive integer" >&2
    exit 1
fi

# Convert time to HH:MM:SS format
HOURS=$((TIME_LIMIT / 60))
MINUTES=$((TIME_LIMIT % 60))
TIME_FORMATTED=$(printf "%02d:%02d:00" $HOURS $MINUTES)

# Build qsub command
if [ -n "$RESERVATION_ID" ]; then
    QSUB_CMD="qsub -I -P $PROJECT_GROUP -q $RESERVATION_ID -v RTYPE=$QUEUE_NAME -l select=1 -l walltime=$TIME_FORMATTED -N $JOB_NAME"
else
    QSUB_CMD="qsub -I -P $PROJECT_GROUP -q $QUEUE_NAME -l select=1 -l walltime=$TIME_FORMATTED -N $JOB_NAME"
fi

# Display job info
echo "Starting interactive job with:"
echo "  Project: $PROJECT_GROUP"
if [ -n "$RESERVATION_ID" ]; then
    echo "  Reservation: $RESERVATION_ID"
fi
echo "  Resource type: $QUEUE_NAME"
case $QUEUE_NAME in
    rt_HG) echo "  Resources: 1 GPU, 16 CPUs, 160GB" ;;
    rt_HF) echo "  Resources: 8 GPUs, 192 CPUs, 1920GB (full node)" ;;
    rt_HC) echo "  Resources: CPU-only, 32 CPUs, 320GB" ;;
esac
echo "  Time limit: $TIME_LIMIT minutes ($TIME_FORMATTED)"
echo "  Job name: $JOB_NAME"
echo "  Command: $QSUB_CMD"
echo

# Execute qsub command
exec $QSUB_CMD
